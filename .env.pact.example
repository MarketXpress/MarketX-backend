# Pact Contract Testing Configuration
# Copy this file to .env.pact and fill in your values

# ============================================
# Pact Broker Configuration (Optional)
# ============================================
# Use a Pact Broker for centralized contract management
# Options: Self-hosted or Pactflow (https://pactflow.io/)

PACT_BROKER_URL=http://localhost:9292
PACT_BROKER_TOKEN=
PACT_BROKER_USERNAME=
PACT_BROKER_PASSWORD=

# ============================================
# Provider Configuration
# ============================================
# Base URL where the provider (backend) is running during tests
PROVIDER_BASE_URL=http://localhost:3000

# Git information for versioning
GIT_COMMIT=local
GIT_BRANCH=local

# ============================================
# Test Configuration
# ============================================
# Authentication token for testing protected endpoints
PACT_TEST_AUTH_TOKEN=test-auth-token-for-pact-testing

# Enable WIP (Work In Progress) pacts
# Date from which to include WIP pacts (ISO 8601 format)
WIP_PACTS_SINCE=2026-01-01

# ============================================
# Logging
# ============================================
# Log level: trace, debug, info, warn, error
PACT_LOG_LEVEL=info

# ============================================
# CI/CD Configuration
# ============================================
# Set to 'true' in CI environments
CI=false

# Node environment
NODE_ENV=test
