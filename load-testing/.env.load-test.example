# Load Testing Environment Configuration
# Copy this file to .env.load-test and update with your values

# Target URL for load testing
# For local testing: http://localhost:3000
# For staging: https://staging.marketx.com
# For production: https://api.marketx.com (use with caution!)
TARGET_URL=http://localhost:3000

# API Version
API_VERSION=v1

# Test Environment Identifier
ENVIRONMENT=staging

# Artillery Configuration
ARTILLERY_WORKERS=4
ARTILLERY_OUTPUT_DIR=./load-testing/reports

# K6 Configuration
K6_VUS=200
K6_DURATION=5m
K6_OUT=json=./load-testing/reports/k6-results.json

# Test Data Configuration
TEST_USER_EMAIL=loadtest@example.com
TEST_USER_PASSWORD=LoadTest123!

# Optional: Authentication Token (if testing authenticated endpoints)
# Generate this by logging in to your application
AUTH_TOKEN=

# Optional: Database connection for test data setup
DB_HOST=localhost
DB_PORT=5432
DB_NAME=marketx_test
DB_USER=postgres
DB_PASSWORD=postgres

# Optional: Redis connection for cache testing
REDIS_HOST=localhost
REDIS_PORT=6379

# Test Execution Options
# Set to 'true' to enable verbose logging
VERBOSE=false

# Set to 'true' to skip SSL certificate validation (for self-signed certs)
SKIP_SSL_VERIFY=false

# Maximum number of concurrent connections
MAX_CONNECTIONS=200

# Request timeout in seconds
REQUEST_TIMEOUT=30

# Think time between requests (in seconds)
THINK_TIME_MIN=1
THINK_TIME_MAX=3

# Report Generation
GENERATE_HTML_REPORT=true
GENERATE_JSON_REPORT=true
GENERATE_CSV_REPORT=false

# Monitoring Integration (Optional)
# Grafana/Prometheus endpoints for real-time monitoring
GRAFANA_URL=
PROMETHEUS_URL=

# Slack/Discord webhook for notifications
SLACK_WEBHOOK_URL=
DISCORD_WEBHOOK_URL=

# Performance Thresholds
# Tests will fail if these thresholds are exceeded
THRESHOLD_ERROR_RATE=0.05
THRESHOLD_P95_RESPONSE_TIME=2000
THRESHOLD_P99_RESPONSE_TIME=5000
THRESHOLD_AVG_RESPONSE_TIME=1000

# Memory and Resource Monitoring
MONITOR_MEMORY=true
MONITOR_CPU=true
MONITOR_NETWORK=true

# Test Data Volume
# Number of products to query
PRODUCT_POOL_SIZE=1000

# Number of orders to query
ORDER_POOL_SIZE=500

# Number of users to simulate
USER_POOL_SIZE=200

# Scenario Weights (should sum to 100)
WEIGHT_PRODUCT_QUERIES=40
WEIGHT_ORDER_QUERIES=30
WEIGHT_CATEGORY_QUERIES=15
WEIGHT_ANALYTICS_QUERIES=10
WEIGHT_ADMIN_QUERIES=5
