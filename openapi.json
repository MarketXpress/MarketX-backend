  "info": {
    "title": "MarketX API",
    "description": "MarketX backend API documentation",
    "version": "1.0",
    "contact": {}
  },
  "tags": [],
  "servers": [],
  "components": {
    "securitySchemes": {
      "bearer": {
        "scheme": "bearer",
        "bearerFormat": "JWT",
        "type": "http"
      }
    },
    "schemas": {
      "CreateUserDto": {
        "type": "object",
        "properties": {
          "email": {
            "type": "string",
            "example": "jane.doe@example.com"
          },
          "password": {
            "type": "object",
            "example": "StrongPassword123"
          },
          "name": {
            "type": "string",
            "example": "Jane Doe"
          },
          "bio": {
            "type": "string",
            "example": "Software developer with 5 years experience"
          },
          "avatarUrl": {
            "type": "string",
            "example": "https://example.com/avatar.jpg"
          },
          "language": {
            "type": "string",
            "example": "en",
            "enum": [
              "en",
              "es",
              "fr"
            ]
          },
          "oauthProvider": {
            "type": "object",
            "example": "google"
          },
          "oauthProviderId": {
            "type": "object",
            "example": "google-uid-123"
          }
        },
        "required": [
          "email",
          "name"
        ]
      },
      "Users": {
        "type": "object",
        "properties": {
          "verificationStatus": {
            "type": "string",
            "enum": [
              "pending",
              "verified",
              "rejected",
              "expired"
            ]
          },
          "verificationLevel": {
            "type": "string",
            "enum": [
              "basic",
              "enhanced",
              "full"
            ]
          },
          "subscriptionTier": {
            "type": "string",
            "enum": [
              "free",
              "basic",
              "premium",
              "enterprise"
            ]
          },
          "subscriptionStatus": {
            "type": "string",
            "enum": [
              "active",
              "inactive",
              "cancelled",
              "expired"
            ]
          }
        },
        "required": [
          "verificationStatus",
          "verificationLevel",
          "subscriptionTier",
          "subscriptionStatus"
        ]
      },
      "UpdateProfileDto": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string",
            "description": "User full name",
            "example": "John Doe"
          },
          "bio": {
            "type": "string",
            "description": "User bio/description",
            "example": "Software developer passionate about clean code"
          },
          "avatarUrl": {
            "type": "string",
            "description": "URL to user profile image",
            "example": "https://example.com/avatar.jpg"
          },
          "language": {
            "type": "string",
            "description": "Preferred language (e.g., en, es, fr)",
            "example": "en"
          }
        }
      },
      "CreateCategoryDto": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string",
            "example": "Electronics"
          },
          "description": {
            "type": "string",
            "example": "Phones, laptops, accessories"
          },
          "icon": {
            "type": "string",
            "example": "mdi:monitor"
          },
          "isActive": {
            "type": "boolean",
            "example": true
          },
          "parentId": {
            "type": "object",
            "example": 1,
            "description": "Parent category id (null for root)"
          }
        },
        "required": [
          "name"
        ]
      },
      "CreateProductDto": {
        "type": "object",
        "properties": {}
      },
      "UpdateProductDto": {
        "type": "object",
        "properties": {}
      },
      "UpdatePriceDto": {
        "type": "object",
        "properties": {}
      },
      "CreateOrderDto": {
        "type": "object",
        "properties": {}
      },
      "UpdateOrderStatusDto": {
        "type": "object",
        "properties": {}
      },
      "StellarWebhookDto": {
        "type": "object",
        "properties": {}
      },
      "CreateNotificationDto": {
        "type": "object",
        "properties": {}
      },
      "CreateReviewDto": {
        "type": "object",
        "properties": {}
      },
      "CreateEscrowDto": {
        "type": "object",
        "properties": {
          "amount": {
            "type": "number",
            "description": "Amount of XLM to hold in escrow",
            "example": 100
          },
          "buyerId": {
            "type": "string",
            "description": "UUID of the buyer initiating the escrow",
            "example": "a1b2c3d4-e5f6-7890-abcd-ef1234567890"
          },
          "sellerId": {
            "type": "string",
            "description": "UUID of the seller who will receive the funds on release",
            "example": "b2c3d4e5-f6a7-8901-bcde-f12345678901"
          }
        },
        "required": [
          "amount",
          "buyerId",
          "sellerId"
        ]
      }
    }
  }
