model Escrow {
  id             String   @id @default(uuid())
  amount         Int
  status         String
  releasedAmount Int?     // new
  refundedAmount Int?     // new
  sellerId       String
  buyerId        String
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

model User {
  id            String   @id @default(uuid())
  email         String   @unique
  password      String
  twoFAEnabled  Boolean  @default(false)
  twoFASecret   String?  // securely stored TOTP secret
  // ...
}

